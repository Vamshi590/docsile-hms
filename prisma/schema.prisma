// Docsile HMS - Hospital Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH & USERS ───────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  phone        String?
  role         String    @default("RECEPTIONIST") // ADMIN, DOCTOR, RECEPTIONIST, OPTOMETRIST, NURSE
  department   String?
  designation  String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdPatients Patient[]      @relation("CreatedBy")
  prescriptions   Prescription[]
  eyeReadings     EyeReading[]   @relation("CreatedByUser")
  inpatients      InPatient[]    @relation("InPatientCreatedBy")
  insuranceClaims InsuranceClaim[] @relation("InsuranceCreatedBy")
}

// ─── HOSPITAL PROFILE ───────────────────────────────

model HospitalProfile {
  id             String   @id @default(cuid())
  name           String
  displayName    String?
  address        String?  @db.Text
  phone          String?
  email          String?
  website        String?
  logoUrl        String?
  registrationNo String?
  gstin          String?
  settings       String   @default("{}") @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── SERVICE TEMPLATES ──────────────────────────────

model ServiceTemplate {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  amount      Float    @default(0)
  discount    Float    @default(0)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

// ─── PATIENTS ───────────────────────────────────────

model Patient {
  id               String    @id @default(cuid())
  patientId        String    @unique
  firstName        String
  lastName         String?
  dateOfBirth      DateTime?
  age              Int?
  gender           String
  phone            String
  email            String?
  address          String?   @db.Text
  guardianName     String?
  guardianRelation String?
  emergencyContact String?   @db.Text
  referredBy       String?
  doctorName       String?
  department       String?
  patientType      String    @default("OPD")
  status           String    @default("REGISTERED")
  appointmentDate  DateTime
  movedFromDate    DateTime?
  movedToDate      DateTime?
  moveReason       String?
  notes            String?   @db.Text
  createdById      String?
  createdBy        User?     @relation("CreatedBy", fields: [createdById], references: [id])
  updatedBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  eyeReadings   EyeReading[]
  prescriptions Prescription[]
  inpatient     InPatient?
  labBills      LabBill[]

  @@index([phone])
  @@index([firstName])
  @@index([lastName])
  @@index([appointmentDate])
  @@index([patientType])
  @@index([status])
}

// ─── PRESCRIPTIONS (combines medical + billing) ─────

model Prescription {
  id                 String    @id @default(cuid())
  prescriptionNumber String?   @unique
  patientId          String
  patient            Patient   @relation(fields: [patientId], references: [patientId])
  patientType        String    @default("OPD")

  // Doctor / medical fields
  doctorId           String?
  doctor             User?     @relation(fields: [doctorId], references: [id])
  doctorName         String?
  department         String?
  temperature        Float?
  pulseRate          Int?
  spo2               Int?
  presentComplaint   String?   @db.Text
  previousHistory    String?   @db.Text
  diagnosis          String?   @db.Text
  additionalNotes    String?   @db.Text
  medicines          String    @default("[]") @db.Text
  investigations     String    @default("[]") @db.Text
  followUpDate       DateTime?
  notes              String?   @db.Text

  // Billing / invoice fields (merged from Invoice)
  subtotal           Float     @default(0)
  discount           Float     @default(0)
  discountReason     String?
  total              Float     @default(0)
  amountPaid         Float     @default(0)
  balanceDue         Float     @default(0)
  paymentMode        String?
  paymentDate        DateTime?

  status             String    @default("DRAFT")
  prescriptionDate   DateTime
  createdBy          String
  updatedBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  items      InvoiceItem[]
  payments   Payment[]
  eyeReading EyeReading?
  labBills   LabBill[]

  @@index([patientId])
  @@index([prescriptionDate])
  @@index([doctorName])
  @@index([status])
}

// ─── PRESCRIPTION LINE ITEMS (formerly InvoiceItem) ──

model InvoiceItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  description    String
  category       String?
  quantity       Int          @default(1)
  unitPrice      Float
  amount         Float
  sortOrder      Int          @default(0)
}

// ─── PAYMENTS ────────────────────────────────────────

model Payment {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  amount         Float
  paymentMode    String
  paymentRef     String?
  receivedBy     String?
  paymentDate    DateTime     @default(now())
  notes          String?
}

// ─── EYE READINGS (WORKUP MODULE) ──────────────────

model EyeReading {
  id                   String        @id @default(cuid())
  patientId            String
  patient              Patient       @relation(fields: [patientId], references: [patientId])
  prescriptionId       String?       @unique
  prescription         Prescription? @relation(fields: [prescriptionId], references: [id])
  autoRefractometer    String?       @db.Text
  glassesReading       String?       @db.Text
  previousPrescription String?       @db.Text
  presentPrescription  String?       @db.Text
  clinicalFindings     String?       @db.Text
  readingDate          DateTime
  status               String        @default("COMPLETED")
  createdById          String?
  createdBy            User?         @relation("CreatedByUser", fields: [createdById], references: [id])
  updatedBy            String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([patientId])
  @@index([readingDate])
  @@index([status])
}

// ─── CLINICAL CONFIGURATIONS ─────────────────────

model PredefinedTemplate {
  id                   String   @id @default(cuid())
  code                 String   @unique
  name                 String
  presentComplaint     String?  @db.Text
  previousHistory      String?  @db.Text
  provisionalDiagnosis String?  @db.Text
  medicines            String   @default("[]") @db.Text
  investigations       String   @default("[]") @db.Text
  followUpDays         Int?
  additionalNotes      String?  @db.Text
  isActive             Boolean  @default(true)
  createdBy            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model MedicineMaster {
  id            String   @id @default(cuid())
  name          String   @unique
  defaultTiming String?
  defaultDays   String?
  category      String?
  note          String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model InvestigationMaster {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])

  labInvestigations LabInvestigation[]
}

model DropdownOption {
  id        String   @id @default(cuid())
  fieldName String
  value     String
  createdBy String
  createdAt DateTime @default(now())

  @@unique([fieldName, value])
  @@index([fieldName])
}

// ─── PREDEFINED PACKAGES ────────────────────────────

model PredefinedPackage {
  id          String   @id @default(cuid())
  name        String   @unique
  inclusions  String   @default("[]") @db.Text  // JSON array of PackageInclusion
  totalAmount Float    @default(0)
  discount    Float    @default(0)
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// ─── INPATIENTS ─────────────────────────────────────

model InPatient {
  id                  String    @id @default(cuid())
  patientId           String    @unique
  patient             Patient   @relation(fields: [patientId], references: [id])
  ipNumber            String    @unique

  name                String
  age                 Int
  gender              String
  phone               String
  address             String?   @db.Text
  dateOfBirth         DateTime?
  guardianName        String?

  admissionDate       DateTime
  admissionNotes      String?   @db.Text
  referredBy          String?
  department          String?
  doctorNames         String    @default("[]") @db.Text
  onDutyDoctor        String?

  operationName       String?
  operationDate       DateTime?
  operationProcedure  String?
  operationDetails    String?   @db.Text
  provisionDiagnosis  String?

  medicalValues       String?   @db.Text

  packageAmount       Float     @default(0)
  packageInclusions   String?   @db.Text
  discount            Float     @default(0)
  netAmount           Float     @default(0)
  totalReceivedAmount Float     @default(0)
  balanceAmount       Float     @default(0)
  paymentRecords      String?   @db.Text

  prescriptions       String?   @db.Text
  followUpDate        DateTime?

  status              String    @default("ADMITTED")
  dischargeDate       DateTime?
  dischargeNotes      String?   @db.Text

  bedNumber           String?
  wardName            String?

  createdById         String?
  createdBy           User?     @relation("InPatientCreatedBy", fields: [createdById], references: [id])
  updatedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  insuranceClaims InsuranceClaim[]

  @@index([status])
  @@index([admissionDate])
  @@index([department])
}

// ─── INSURANCE COMPANIES (Master List) ─────────────

model InsuranceCompany {
  id            String   @id @default(cuid())
  name          String   @unique
  tpaName       String?
  contactNumber String?
  email         String?
  address       String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  claims InsuranceClaim[]

  @@index([isActive])
}

// ─── INSURANCE CLAIMS ──────────────────────────────

model InsuranceClaim {
  id                    String    @id @default(cuid())
  claimNumber           String    @unique
  inPatientId           String
  inPatient             InPatient @relation(fields: [inPatientId], references: [id])
  insuranceCompanyId    String?
  insuranceCompany      InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id])

  // Patient info (snapshot)
  patientName           String
  ipNumber              String
  age                   Int
  gender                String
  phone                 String
  guardianName          String?
  department            String?
  doctorNames           String    @default("[]") @db.Text
  operationName         String?
  provisionDiagnosis    String?
  admissionDate         DateTime
  dischargeDate         DateTime?

  // Insurance details
  insuranceCompanyName  String
  tpaName               String?
  policyNumber          String?
  policyHolderName      String?
  insuranceCardNumber   String?
  relationToInsured     String?

  // Financial
  packageAmount         Float     @default(0)
  totalBillAmount       Float     @default(0)
  preauthAmount         Float     @default(0)
  enhancementAmount     Float     @default(0)
  enhancementApproved   Float     @default(0)
  totalApprovedAmount   Float     @default(0)
  finalSettledAmount    Float     @default(0)
  deductions            Float     @default(0)
  discount              Float     @default(0)
  patientPayableAmount  Float     @default(0)
  patientPaidAmount     Float     @default(0)
  patientBalance        Float     @default(0)

  // Status
  status                String    @default("PREAUTH_SUBMITTED")

  // Tracking
  preauthSubmittedDate  DateTime?
  preauthApprovedDate   DateTime?
  preauthRejectionReason String?  @db.Text
  preauthQueryNotes     String?   @db.Text
  enhancementClaimedDate  DateTime?
  enhancementApprovedDate DateTime?
  enhancementRejectionReason String? @db.Text
  enhancementQueryNotes String?   @db.Text
  finalBillSubmittedDate DateTime?
  settlementDate        DateTime?
  settlementReference   String?

  // JSON fields
  statusHistory         String?   @db.Text
  notes                 String?   @db.Text
  packageInclusions     String?   @db.Text

  // Audit
  createdById           String?
  createdBy             User?     @relation("InsuranceCreatedBy", fields: [createdById], references: [id])
  updatedBy             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status])
  @@index([insuranceCompanyName])
  @@index([createdAt])
  @@index([inPatientId])
}

// ─── LABS MODULE ──────────────────────────────────────

model Lab {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  location    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  investigations LabInvestigation[]
  labBills       LabBill[]
}

model LabInvestigation {
  id              String  @id @default(cuid())
  labId           String
  investigationId String
  amount          Float
  isDefault       Boolean @default(false)
  isActive        Boolean @default(true)

  lab             Lab                 @relation(fields: [labId], references: [id], onDelete: Cascade)
  investigation   InvestigationMaster @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@unique([labId, investigationId])
  @@index([investigationId])
}

model LabBill {
  id               String    @id @default(cuid())
  billNumber       String    @unique
  labId            String
  patientId        String
  prescriptionId   String

  subtotal         Float     @default(0)
  discount         Float     @default(0)
  discountReason   String?
  total            Float     @default(0)
  amountPaid       Float     @default(0)
  balanceDue       Float     @default(0)

  paymentMode      String?
  paymentDate      DateTime?
  status           String    @default("PENDING")

  notes            String?
  createdBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lab              Lab          @relation(fields: [labId], references: [id])
  patient          Patient      @relation(fields: [patientId], references: [patientId])
  prescription     Prescription @relation(fields: [prescriptionId], references: [id])
  items            LabBillItem[]
  payments         LabPayment[]

  @@index([patientId])
  @@index([labId])
  @@index([status])
  @@index([createdAt])
}

model LabBillItem {
  id              String  @id @default(cuid())
  labBillId       String
  investigationId String?
  name            String
  amount          Float
  sortOrder       Int     @default(0)

  labBill         LabBill @relation(fields: [labBillId], references: [id], onDelete: Cascade)
}

model LabPayment {
  id          String   @id @default(cuid())
  labBillId   String
  amount      Float
  paymentMode String
  paymentRef  String?
  receivedBy  String?
  paymentDate DateTime @default(now())
  notes       String?

  labBill     LabBill  @relation(fields: [labBillId], references: [id], onDelete: Cascade)
}

// ─── EXPENSES MODULE ─────────────────────────────────

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6B7280")
  icon      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses Expense[]

  @@unique([name])
  @@index([isActive])
  @@index([sortOrder])
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount      Float
  date        DateTime
  reason      String?  @db.Text
  paymentMode String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([date])
  @@index([createdAt])
}

// ─── PHARMACY MODULE ─────────────────────────────────

model PharmacyMedicine {
  id             String   @id @default(cuid())
  name           String
  genericName    String?
  manufacturer   String?
  composition    String?
  category       String?  // Tablet, Capsule, Syrup, Injection, etc.
  dosageForm     String?
  strength       String?
  unitOfMeasure  String   @default("Nos") // Nos, Strip, Bottle, Vial, etc.
  hsnCode        String?
  gstPercent     Float    @default(12)
  scheduleType   String?  // H, H1, X, OTC
  isActive       Boolean  @default(true)
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockEntries      PharmacyStock[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([name, manufacturer])
  @@index([name])
  @@index([genericName])
  @@index([category])
  @@index([isActive])
}

model PharmacyStock {
  id             String    @id @default(cuid())
  medicineId     String
  medicine       PharmacyMedicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  batchNumber    String
  quantity       Int       @default(0)
  mrp            Float     @default(0)
  costPrice      Float     @default(0)
  gstPercent     Float     @default(12)
  unitsPerPack   Int       @default(1)
  expiryDate     DateTime
  manufacturingDate DateTime?
  supplierId     String?
  supplier       PharmacySupplier? @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  isActive       Boolean   @default(true)
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  billItems      PharmacyBillItem[]

  @@unique([medicineId, batchNumber])
  @@index([medicineId])
  @@index([batchNumber])
  @@index([expiryDate])
  @@index([supplierId])
}

model PharmacySupplier {
  id             String   @id @default(cuid())
  name           String   @unique
  contactPerson  String?
  phone          String?
  email          String?
  address        String?  @db.Text
  gstin          String?
  drugLicenseNo  String?
  creditDays     Int      @default(30)
  isActive       Boolean  @default(true)
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockEntries    PharmacyStock[]
  purchaseOrders  PurchaseOrder[]

  @@index([isActive])
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  supplierId      String
  supplier        PharmacySupplier @relation(fields: [supplierId], references: [id])
  orderDate       DateTime @default(now())
  expectedDate    DateTime?
  invoiceNumber   String?
  invoiceDate     DateTime?
  subtotal        Float    @default(0)
  gstAmount       Float    @default(0)
  discount        Float    @default(0)
  totalAmount     Float    @default(0)
  amountPaid      Float    @default(0)
  balanceDue      Float    @default(0)
  paymentMode     String?
  status          String   @default("DRAFT") // DRAFT, ORDERED, PARTIALLY_RECEIVED, RECEIVED, CANCELLED
  notes           String?  @db.Text
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  medicineId      String
  medicine        PharmacyMedicine @relation(fields: [medicineId], references: [id])
  batchNumber     String?
  quantity        Int      @default(0)
  receivedQty     Int      @default(0)
  costPrice       Float    @default(0)
  mrp             Float    @default(0)
  gstPercent      Float    @default(12)
  expiryDate      DateTime?
  amount          Float    @default(0)

  @@index([purchaseOrderId])
  @@index([medicineId])
}

model PharmacyBill {
  id              String   @id @default(cuid())
  billNumber      String   @unique
  patientId       String?
  patientName     String
  patientPhone    String?
  gender          String?
  email           String?
  referredDoctor  String?
  prescriptionId  String?
  billDate        DateTime @default(now())
  subtotal        Float    @default(0)
  discountPercent Float    @default(0)
  discountAmount  Float    @default(0)
  gstAmount       Float    @default(0)
  netAmount       Float    @default(0)
  roundOff        Float    @default(0)
  billAmount      Float    @default(0)
  paidAmount      Float    @default(0)
  balanceDue      Float    @default(0)
  paymentMode     String   @default("CASH")
  paymentRef      String?
  status          String   @default("COMPLETED") // COMPLETED, RETURNED, CANCELLED
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           PharmacyBillItem[]

  @@index([patientId])
  @@index([billDate])
  @@index([status])
}

model PharmacyBillItem {
  id              String   @id @default(cuid())
  billId          String
  bill            PharmacyBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  stockId         String
  stock           PharmacyStock @relation(fields: [stockId], references: [id])
  medicineName    String
  batchNumber     String
  quantity        Int      @default(1)
  mrp             Float    @default(0)
  price           Float    @default(0)
  total           Float    @default(0)
  discountPercent Float    @default(0)
  amount          Float    @default(0)
  gstPercent      Float    @default(0)

  @@index([billId])
  @@index([stockId])
}
